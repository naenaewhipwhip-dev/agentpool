{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/agentpool/agentpool/schema/tip.json",
  "title": "Tip",
  "description": "A community-contributed tip entry in the AgentPool knowledge registry.",
  "type": "object",
  "required": ["type", "title", "content"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^tip-[0-9a-f]{8}$",
      "description": "Unique identifier, auto-generated as tip-<8hex>"
    },
    "type": {
      "type": "string",
      "const": "tip",
      "description": "Entry type discriminator"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable title for the tip"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "The tip content"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Searchable tags"
    },
    "frameworks": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Relevant frameworks or libraries"
    },
    "contributor": {
      "type": "string",
      "default": "anonymous",
      "description": "GitHub handle or display name of the contributor"
    },
    "created": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Creation date in YYYY-MM-DD format"
    },
    "votes": {
      "type": "integer",
      "default": 0,
      "description": "Net community vote count"
    }
  },
  "additionalProperties": false
}
